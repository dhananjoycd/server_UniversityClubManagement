model SiteSetting {
  id               String   @id @default(cuid())
  organizationName String
  logoUrl          String?
  contactEmail     String?
  phone            String?
  socialLinks      Json?
  heroSlides       Json?
  impactStats      Json?
  faqs             Json?
  testimonials     Json?
  committeeMembers Json?
  aboutText        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
