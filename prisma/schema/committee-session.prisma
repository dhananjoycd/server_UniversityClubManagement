model CommitteeSession {
  id          String               @id @default(cuid())
  label       String               @unique
  title       String?
  description  String?
  coverImageUrl String?
  isActive     Boolean              @default(false)
  displayOrder Int                 @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments CommitteeAssignment[]
}

model CommitteeAssignment {
  id              String           @id @default(cuid())
  sessionId       String
  memberProfileId String
  committeeWing   String
  positionTitle   String
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  bioOverride     String?
  photoUrlOverride String?
  facebookUrl     String?
  linkedinUrl     String?
  whatsapp        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  session         CommitteeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  memberProfile   MemberProfile    @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberProfileId])
  @@index([sessionId, sortOrder])
}
